pipeline {
    agent {
        kubernetes {
            yaml '''
apiVersion: v1
kind: Pod
spec:
  containers:
  - name: gcloud
    image: google/cloud-sdk:latest
    command:
    - cat
    tty: true
'''
        }
    }

    environment {
        PROJECT_ID = credentials('project_id')
        REPO_PATH = credentials('repo_path')
        CLUSTER_NAME = credentials('cluster_name')
        CLUSTER_ZONE = credentials('cluster_zone')
    }

    stages {

        stage('Test') {
            steps {
                sh 'mvn test'
            }
        }

        stage('Build') {
            steps {
                sh 'mvn package'
            }
        }

        stage('Containerize') {
            steps {
                container('gcloud') {
                    sh '''
                    gcloud auth activate-service-account --key-file=$service_account
                    gcloud config set project $PROJECT_ID
                    docker build -t $REPO_PATH/binarycalculator .
                    docker push $REPO_PATH/binarycalculator
                    '''
                }
            }
        }

        stage('Deploy') {
            steps {
                container('gcloud') {
                    sh '''
                    gcloud container clusters get-credentials $CLUSTER_NAME --zone $CLUSTER_ZONE
                    kubectl delete deployment binarycalculator || true
                    kubectl create deployment binarycalculator --image=$REPO_PATH/binarycalculator
                    '''
                }
            }
        }

        stage('Service') {
            steps {
                container('gcloud') {
                    sh '''
                    kubectl expose deployment binarycalculator --type=LoadBalancer --port 8080 || true
                    kubectl get service
                    '''
                }
            }
        }

    }
}
